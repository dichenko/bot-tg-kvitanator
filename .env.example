NODE_ENV=production

# Telegram
BOT_TOKEN=replace_me
BOT_MODE=webhook
WEBHOOK_URL=https://your-domain.com/webhook
WEBHOOK_PATH=/webhook
BOT_PORT=3000

# Database
POSTGRES_DB=receipt_bot
POSTGRES_USER=receipt_user
POSTGRES_PASSWORD=replace_me
DATABASE_URL=postgresql://receipt_user:replace_me@postgres:5432/receipt_bot?schema=public

# Renderer
RENDERER_URL=http://renderer-worker:3001
RENDERER_PORT=3001

# Files
RECEIPTS_DIR=/app/storage/receipts
EXPORTS_DIR=/app/storage/exports

# App
APP_TIMEZONE=Europe/Moscow

NODE_ENV=production

# Telegram
BOT_TOKEN=replace_me
BOT_MODE=webhook
WEBHOOK_URL=https://your-domain.com/webhook
WEBHOOK_PATH=/webhook
BOT_PORT=3000

# MAX
ENABLE_MAX=false
MAX_BOT_TOKEN=replace_me
MAX_WEBHOOK_URL=https://your-domain.com/webhook/max
MAX_WEBHOOK_PATH=/webhook/max
# Optional but recommended. Use only A-Z, a-z, 0-9, _ and -, length 5-256.
MAX_WEBHOOK_SECRET=replace-me

# Database
POSTGRES_DB=receipt_bot
POSTGRES_USER=receipt_user
POSTGRES_PASSWORD=replace_me
POSTGRES_PORT=5432
# Optional. Defaults to `postgres` inside Docker network.
# POSTGRES_HOST=postgres

# Renderer
# Internal Docker service URL. HTTP is correct here because this traffic stays inside the private Docker network.
RENDERER_URL=http://renderer-worker:3001
RENDERER_PORT=3001

# Files
RECEIPTS_DIR=/app/storage/receipts
EXPORTS_DIR=/app/storage/exports

# App
APP_TIMEZONE=Europe/Moscow

{
  "name": "receipt-bot",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "build": "pnpm -r build",
    "import:legacy-receipts": "node scripts/import-legacy-receipts.cjs",
    "resequence:receipts": "node scripts/resequence-receipts.cjs",
    "postinstall": "pnpm prisma:generate",
    "prisma:generate": "node scripts/run-prisma.cjs generate",
    "prisma:migrate:dev": "node scripts/run-prisma.cjs migrate dev",
    "prisma:migrate:deploy": "node scripts/run-prisma.cjs migrate deploy"
  }
}
